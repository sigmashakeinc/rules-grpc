# grpc_write_safety.rules
# Technology: grpc | Capability: write

rule grpc-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "grpc.credentials.createInsecure()"
  MESSAGE "Blocked an unsafe pattern in grpc. Use the recommended best practices for 2025/2026."
}

rule grpc-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "grpc.load("
  MESSAGE "You are using an outdated API for grpc. Please upgrade to the newer API."
}
